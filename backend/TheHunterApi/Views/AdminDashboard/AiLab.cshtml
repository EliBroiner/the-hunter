@{
    ViewData["Title"] = "AI Lab Debugger";
    Layout = "~/Views/Shared/_Layout.cshtml";
    // פרומפט ניתוח מסמכים: כלל PII — תגיות רק קטגוריות כלליות (Ticket, Receipt), לא שמות/תאריכים/מזהים.
    var defaultSystemPrompt = "Analyze the following document text. Output JSON with: category, date (YYYY-MM-DD or null if unknown), tags (list of keywords), summary (brief).\nReturn ONLY raw JSON - no markdown, no code blocks. Format: {\"category\":\"...\",\"date\":\"yyyy-MM-dd or null\",\"tags\":[\"...\"],\"summary\":\"...\"}\n\n=== STRICT RULE: NO PII IN TAGS ===\nDo NOT include PII or specific record data in tags. Tags only: general categories (Ticket, Receipt, Flight, Travel). No names, IDs, exact dates, locations. Put specifics in metadata/extracted_entities or summary.";
}

<h1 class="mb-4"><i class="bi bi-robot me-2"></i>AI Lab Debugger</h1>

<div id="scanStatsCard" class="alert alert-secondary mb-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <span><strong>Images Skipped (No Text Detected):</strong> <span id="scanStatsCount">—</span></span>
    <small class="text-muted">כסף שנחסך — תמונות שלא נשלחו ל-Google Cloud / Gemini</small>
</div>

<div id="chainLookupCard" class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="bi bi-diagram-3 me-1"></i>Chain of Processing</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small">צפייה בשרשרת עיבוד: [Local OCR -> Failed] -> [Cloud Vision -> Success] -> [Gemini Tagging -> Done]</p>
        <div class="d-flex gap-2 flex-wrap align-items-end">
            <div class="flex-grow-1" style="min-width:200px">
                <label class="form-label small">Document ID</label>
                <input type="text" id="chainDocId" class="form-control" placeholder="מזהה מסמך (Isar ID)">
            </div>
            <button type="button" id="chainFetchBtn" class="btn btn-dark">
                <span class="chainSpinner spinner-border spinner-border-sm d-none me-1"></span>טען
            </button>
        </div>
        <div id="chainResult" class="mt-3 p-3 bg-light rounded font-monospace small d-none"></div>
    </div>
</div>

<div class="row g-4">
    @* Relevance Scorer *@
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-bar-chart me-1"></i>Relevance Scorer</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">שאילתה + מסמך → פירוט ציון (Filename: 200, Content: 120, Metadata: 80)</p>
                <div class="mb-2">
                    <label class="form-label">שאילתה</label>
                    <input type="text" id="scoreQuery" class="form-control" placeholder="חוזה עבודה" value="חוזה">
                </div>
                <div class="mb-2">
                    <label class="form-label">שם קובץ</label>
                    <input type="text" id="scoreFilename" class="form-control" placeholder="חוזה_עבודה_2024.pdf" value="חוזה_עבודה_2024.pdf">
                </div>
                <div class="mb-2">
                    <label class="form-label">תוכן</label>
                    <textarea id="scoreContent" class="form-control" rows="3" placeholder="טקסט מתוך המסמך...">חוזה העסקה בין החברה לעובד. תאריך: 2024-01-15.</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">מטאדאטה (נתיב / קטגוריה)</label>
                    <input type="text" id="scoreMetadata" class="form-control" placeholder="Documents/Contracts" value="Documents/Contracts">
                </div>
                <button type="button" id="scoreBtn" class="btn btn-primary w-100">
                    <span class="scoreSpinner spinner-border spinner-border-sm d-none me-1"></span>חשב ציון
                </button>
                <div id="scoreResult" class="mt-3 p-3 bg-light rounded d-none"></div>
            </div>
        </div>
    </div>

    @* OCR Testing Lab — צעד אחרי צעד *@
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-image me-1"></i>OCR Testing Lab</h5>
            </div>
            <div class="card-body">
                <div id="ocrChainVsXrayInfo" class="alert alert-secondary py-2 mb-3 small">
                    <strong>Chain vs File X-Ray:</strong> OCR Lab — צעד-אחרי-צעד: קובץ → B&W → Cloud Vision → Gemini. File X-Ray — צפייה בנתונים שמורים לפי documentId.
                </div>
                @* שלב 1: בחירת קובץ *@
                <div class="ocr-step mb-3 p-3 border rounded border-primary border-opacity-50">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-primary">1</span>
                        <strong>בחר קובץ</strong>
                    </div>
                    <input type="file" id="ocrLabFile" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.webp">
                    <small id="ocrLabFileName" class="text-muted d-none mt-1"></small>
                </div>
                @* שלב 2: המרה ל-B&W *@
                <div class="ocr-step mb-3 p-3 border rounded">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-secondary">2</span>
                        <strong>המר לשחור-לבן</strong>
                        <span id="ocrLabBwBadge" class="badge bg-success d-none">מוכן</span>
                    </div>
                    <button type="button" id="ocrLabBwBtn" class="btn btn-sm btn-outline-secondary" disabled>
                        <span class="ocrLabBwSpinner spinner-border spinner-border-sm d-none me-1"></span>המר ל-B&W
                    </button>
                    <div id="ocrLabBwPreview" class="mt-2 d-none">
                        <img id="ocrLabBwThumb" src="" alt="B&W" class="img-thumbnail" style="max-width:200px;max-height:150px;">
                    </div>
                </div>
                @* שלב 3: Cloud Vision *@
                <div class="ocr-step mb-3 p-3 border rounded">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-secondary">3</span>
                        <strong>Cloud Vision</strong>
                    </div>
                    <button type="button" id="ocrLabVisionBtn" class="btn btn-sm btn-outline-info" disabled>
                        <span class="ocrLabVisionSpinner spinner-border spinner-border-sm d-none me-1"></span>שלח ל-Cloud Vision
                    </button>
                    <div id="ocrLabVisionResult" class="mt-2 d-none">
                        <label class="form-label small text-muted">טקסט מחולץ</label>
                        <pre id="ocrLabVisionText" class="p-2 bg-light rounded small mb-0 font-monospace" style="max-height:150px;overflow:auto;white-space:pre-wrap" dir="rtl"></pre>
                    </div>
                </div>
                @* שלב 4: Gemini *@
                <div class="ocr-step mb-3 p-3 border rounded">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-secondary">4</span>
                        <strong>Gemini (עם Prompt)</strong>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">System Prompt (אופציונלי — ריק = ברירת מחדל)</label>
                        <textarea id="ocrLabGeminiPrompt" class="form-control form-control-sm font-monospace" rows="3" placeholder="ריק = פרומפט ברירת מחדל מהמערכת"></textarea>
                    </div>
                    <button type="button" id="ocrLabGeminiBtn" class="btn btn-sm btn-info" disabled>
                        <span class="ocrLabGeminiSpinner spinner-border spinner-border-sm d-none me-1"></span>שלח ל-Gemini
                    </button>
                    <div id="ocrLabGeminiResult" class="mt-2 d-none">
                        <pre id="ocrLabGeminiJson" class="p-2 bg-dark text-light rounded small mb-0 font-monospace" style="max-height:200px;overflow:auto"></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Garbage Filter *@
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-funnel me-1"></i>Garbage Filter Simulator</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">יחס ג'יבריש — סף 30%. מעליו הטקסט לא נשלח ל-AI.</p>
                <div class="mb-3">
                    <label class="form-label">טקסט לבדיקה</label>
                    <textarea id="garbageText" class="form-control font-monospace" rows="5" placeholder="הדבק טקסט מחולץ מ-PDF/OCR...">שלום, זהו מסמך בעברית. 123 ו-English letters. תווים תקינים עוברים.</textarea>
                </div>
                <button type="button" id="garbageBtn" class="btn btn-warning w-100">
                    <span class="garbageSpinner spinner-border spinner-border-sm d-none me-1"></span>בדוק ג'יבריש
                </button>
                <div id="garbageResult" class="mt-3 p-3 bg-light rounded d-none"></div>
            </div>
        </div>
    </div>

    @* Prompt Playground *@
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-chat-dots me-1"></i>Prompt Playground</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">הרצת Prompts מול Gemini מהשרת. מפתחות API לא נחשפים ל-Client.</p>
                <div id="manualOverrideBanner" class="alert alert-info alert-dismissible fade show d-none mb-3" role="alert">
                    <strong>Manual Override:</strong> <span id="manualOverrideFilename"></span>
                    <span id="manualOverrideReason" class="ms-2 text-muted small"></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label">System Prompt</label>
                        <textarea id="playgroundSystem" class="form-control font-monospace" rows="6">@defaultSystemPrompt</textarea>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">User Query / תוכן</label>
                        <textarea id="playgroundUser" class="form-control font-monospace" rows="6" placeholder="הדבק תוכן מסמך או שאילתה...">חשבונית מס' 12345. תאריך: 2024-02-10. ספק: חברת ABC.</textarea>
                    </div>
                </div>
                <button type="button" id="playgroundBtn" class="btn btn-success mt-3 w-100">
                    <span class="playgroundSpinner spinner-border spinner-border-sm d-none me-1"></span>הרץ ברקע
                </button>
                <div id="playgroundResult" class="mt-3 p-3 bg-dark text-light rounded font-monospace small d-none" style="max-height:400px;overflow:auto;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const base = '/admin/debug';
    function escapeHtml(s) { return (s+'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    // טעינת Scan Stats
    fetch(base + '/scan-stats', { credentials: 'same-origin' })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(d) {
            if (d && d.imagesSkippedNoText != null) {
                document.getElementById('scanStatsCount').textContent = d.imagesSkippedNoText.toLocaleString();
            }
        })
        .catch(function() { });

    // Chain of Processing
    document.getElementById('chainFetchBtn').addEventListener('click', async function() {
        var docId = document.getElementById('chainDocId').value.trim();
        if (!docId) return;
        var btn = this, spinner = btn.querySelector('.chainSpinner'), out = document.getElementById('chainResult');
        btn.disabled = true; spinner.classList.remove('d-none'); out.classList.add('d-none');
        try {
            var r = await fetch(base + '/processing-chain/' + encodeURIComponent(docId), { credentials: 'same-origin' });
            if (!r.ok) {
                out.textContent = r.status === 404 ? 'לא נמצא' : 'שגיאה: ' + r.status;
            } else {
                var d = await r.json();
                out.textContent = d.chain || '(ריק)';
            }
            out.classList.remove('d-none');
        } catch (e) {
            out.textContent = 'שגיאה: ' + e.message;
            out.classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    // טעינת failureId מ-URL — pre-fill Playground עם טקסט נכשל (Manual Override)
    (function loadFailureFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const failureId = params.get('failureId');
        if (!failureId) return;
        fetch(base + '/scan-failure/' + encodeURIComponent(failureId), { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('לא נמצא');
                return r.json();
            })
            .then(function(f) {
                document.getElementById('playgroundUser').value = f.rawText || '';
                document.getElementById('manualOverrideFilename').textContent = f.filename || '(ללא שם)';
                var reasonEl = document.getElementById('manualOverrideReason');
                reasonEl.textContent = f.reasonForUpload ? '— Reason: ' + f.reasonForUpload : '';
                reasonEl.style.display = f.reasonForUpload ? 'inline' : 'none';
                document.getElementById('manualOverrideBanner').classList.remove('d-none');
                document.querySelector('.card-header.bg-success')?.scrollIntoView({ behavior: 'smooth' });
            })
            .catch(function() { });
    })();

    async function post(endpoint, body) {
        const r = await fetch(base + endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            credentials: 'same-origin'
        });
        if (!r.ok) throw new Error(r.status + ' ' + r.statusText);
        return r.json();
    }

    // Relevance Scorer
    document.getElementById('scoreBtn').addEventListener('click', async function() {
        const btn = this, spinner = btn.querySelector('.scoreSpinner'), out = document.getElementById('scoreResult');
        btn.disabled = true; spinner.classList.remove('d-none');
        out.classList.add('d-none');
        try {
            const r = await post('/score', {
                query: document.getElementById('scoreQuery').value,
                filename: document.getElementById('scoreFilename').value,
                content: document.getElementById('scoreContent').value,
                metadata: document.getElementById('scoreMetadata').value
            });
            out.innerHTML = '<strong>מונחים:</strong> ' + (r.terms || []).join(', ') + '<br>' +
                '<strong>פירוט:</strong> ' + r.breakdown + '<br>' +
                '<strong>סה"כ ציון:</strong> ' + r.totalScore;
            out.classList.remove('d-none');
        } catch (e) {
            out.innerHTML = '<span class="text-danger">שגיאה: ' + e.message + '</span>';
            out.classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    // OCR Testing Lab — צעד אחרי צעד
    let ocrLabBwBase64 = null;
    let ocrLabVisionText = '';

    document.getElementById('ocrLabFile').addEventListener('change', function() {
        const f = this.files?.[0];
        const nameEl = document.getElementById('ocrLabFileName');
        const bwBtn = document.getElementById('ocrLabBwBtn');
        if (!f) {
            nameEl.classList.add('d-none');
            bwBtn.disabled = true;
            ocrLabBwBase64 = null;
            ocrLabVisionText = '';
            resetOcrLabSteps2to4();
            return;
        }
        nameEl.textContent = f.name + ' (' + (f.size/1024).toFixed(1) + ' KB)';
        nameEl.classList.remove('d-none');
        bwBtn.disabled = false;
        ocrLabBwBase64 = null;
        ocrLabVisionText = '';
        resetOcrLabSteps2to4();
    });

    function resetOcrLabSteps2to4() {
        document.getElementById('ocrLabBwBadge').classList.add('d-none');
        document.getElementById('ocrLabBwPreview').classList.add('d-none');
        document.getElementById('ocrLabVisionBtn').disabled = true;
        document.getElementById('ocrLabVisionResult').classList.add('d-none');
        document.getElementById('ocrLabGeminiBtn').disabled = true;
        document.getElementById('ocrLabGeminiResult').classList.add('d-none');
    }

    document.getElementById('ocrLabBwBtn').addEventListener('click', async function() {
        const fileInput = document.getElementById('ocrLabFile');
        if (!fileInput.files?.length) return;
        const btn = this, spinner = btn.querySelector('.ocrLabBwSpinner');
        btn.disabled = true; spinner.classList.remove('d-none');
        try {
            const fd = new FormData();
            fd.append('file', fileInput.files[0]);
            const r = await fetch(base + '/ocr-step-bw', { method: 'POST', body: fd, credentials: 'same-origin' });
            const d = await r.json();
            if (!r.ok) throw new Error(d.error || r.status);
            ocrLabBwBase64 = d.bwBase64;
            document.getElementById('ocrLabBwThumb').src = d.bwThumbnailDataUrl || '';
            document.getElementById('ocrLabBwPreview').classList.remove('d-none');
            document.getElementById('ocrLabBwBadge').classList.remove('d-none');
            document.getElementById('ocrLabVisionBtn').disabled = false;
        } catch (e) {
            alert('שגיאה: ' + e.message);
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    document.getElementById('ocrLabVisionBtn').addEventListener('click', async function() {
        if (!ocrLabBwBase64) return;
        const btn = this, spinner = btn.querySelector('.ocrLabVisionSpinner');
        btn.disabled = true; spinner.classList.remove('d-none');
        try {
            const r = await post('/ocr-step-vision', { imageBase64: ocrLabBwBase64 });
            ocrLabVisionText = r.text || '';
            document.getElementById('ocrLabVisionText').textContent = ocrLabVisionText || '(אין טקסט בתמונה)';
            document.getElementById('ocrLabVisionResult').classList.remove('d-none');
            document.getElementById('ocrLabGeminiBtn').disabled = false;
        } catch (e) {
            document.getElementById('ocrLabVisionText').textContent = 'שגיאה: ' + e.message;
            document.getElementById('ocrLabVisionResult').classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    document.getElementById('ocrLabGeminiBtn').addEventListener('click', async function() {
        const text = ocrLabVisionText;
        if (!text || text === '(אין טקסט בתמונה)') {
            alert('הרץ קודם Cloud Vision או הזן טקסט');
            return;
        }
        const btn = this, spinner = btn.querySelector('.ocrLabGeminiSpinner');
        btn.disabled = true; spinner.classList.remove('d-none');
        try {
            const prompt = document.getElementById('ocrLabGeminiPrompt').value.trim();
            const r = await post('/ocr-step-gemini', { text: text, systemPromptOverride: prompt || null });
            const pretty = JSON.stringify(r, null, 2);
            document.getElementById('ocrLabGeminiJson').textContent = pretty;
            document.getElementById('ocrLabGeminiResult').classList.remove('d-none');
        } catch (e) {
            document.getElementById('ocrLabGeminiJson').textContent = 'שגיאה: ' + e.message;
            document.getElementById('ocrLabGeminiResult').classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    // Garbage Filter
    document.getElementById('garbageBtn').addEventListener('click', async function() {
        const btn = this, spinner = btn.querySelector('.garbageSpinner'), out = document.getElementById('garbageResult');
        btn.disabled = true; spinner.classList.remove('d-none');
        out.classList.add('d-none');
        try {
            const r = await post('/garbage-filter', { text: document.getElementById('garbageText').value });
            const pass = r.passesThreshold ? '<span class="text-success">עובר</span>' : '<span class="text-danger">נכשל</span>';
            out.innerHTML = 'אורך: ' + r.textLength + ' תווים | ג\'יבריש: ' + r.garbageCount + ' (' + r.garbageRatioPercent + '%) | סף: ' + r.thresholdPercent + '% | ' + pass;
            out.classList.remove('d-none');
        } catch (e) {
            out.innerHTML = '<span class="text-danger">שגיאה: ' + e.message + '</span>';
            out.classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });

    // Playground
    document.getElementById('playgroundBtn').addEventListener('click', async function() {
        const btn = this, spinner = btn.querySelector('.playgroundSpinner'), out = document.getElementById('playgroundResult');
        btn.disabled = true; spinner.classList.remove('d-none');
        out.classList.add('d-none');
        try {
            const r = await post('/playground', {
                systemPrompt: document.getElementById('playgroundSystem').value,
                userQuery: document.getElementById('playgroundUser').value
            });
            if (r.success) {
                out.textContent = r.rawJson || '(ריק)';
            } else {
                out.innerHTML = '<span class="text-danger">שגיאה: ' + (r.error || 'Unknown') + '</span>';
            }
            out.classList.remove('d-none');
        } catch (e) {
            out.innerHTML = '<span class="text-danger">שגיאה: ' + e.message + '</span>';
            out.classList.remove('d-none');
        }
        btn.disabled = false; spinner.classList.add('d-none');
    });
})();
</script>
}
